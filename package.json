{
  "name": "@heroku/types",
  "version": "0.2.0",
  "description": "Generates Typescript types from API hyperschema",
  "type": "module",
  "exports": {
    "./3.sdk": {
      "types": "./dist/3.sdk/types.d.ts"
    },
    "./3.sdk/routes": {
      "types": "./dist/3.sdk/routes.d.ts",
      "default": "./dist/3.sdk/routes.js"
    },
    "./data": {
      "types": "./dist/data/types.d.ts"
    },
    "./data/routes": {
      "types": "./dist/data/routes.d.ts",
      "default": "./dist/data/routes.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist/",
    "3.sdk/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli.ts",
    "generate:data": "tsx src/gen-data-types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.22.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
