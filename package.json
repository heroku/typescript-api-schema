{
  "name": "@heroku/types",
  "version": "0.1.0",
  "description": "Generates Typescript types from API hyperschema",
  "type": "module",
  "exports": {
    "./3.sdk": {
      "types": "./3.sdk/types.d.ts"
    },
    "./3.sdk/routes": {
      "types": "./3.sdk/routes.d.ts",
      "default": "./3.sdk/routes.js"
    }
  },
  "files": [
    "3.sdk/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "generate": "node dist/cli.js",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
