{
  "name": "@heroku/types",
  "version": "0.1.0",
  "description": "Generates Typescript types from API hyperschema",
  "type": "module",
  "types": "./types/heroku-3.sdk.d.ts",
  "exports": {
    ".": {
      "types": "./types/heroku-3.sdk.d.ts"
    },
    "./routes": {
      "types": "./types/routes.d.ts",
      "default": "./types/routes.js"
    }
  },
  "files": [
    "types/"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "generate": "node dist/cli.js",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
